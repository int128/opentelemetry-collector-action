{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>int128/renovate-base",
    "github>int128/typescript-action-renovate-config#v2.0.0",
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["action.yaml"],
      "matchStrings": ["otel/opentelemetry-collector-contrib:(?<currentValue>[a-z0-9\\.]+)"],
      "depNameTemplate": "otel/opentelemetry-collector-contrib",
      "datasourceTemplate": "docker"
    }
  ],
  "platformAutomerge": true
}
